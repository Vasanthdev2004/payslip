# Copy to .env.local for local dev. All values here are safe placeholders.

# WalletConnect project id (optional). Injected wallets (MetaMask) work without it.
# Get one free at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=KRED_DEMO

# Public app URL (used to build shareable request / verify links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Prisma metadata store (tags + disclosures only — never amounts).
# Postgres everywhere (Railway managed PG in deploy; use your own locally).
DATABASE_URL="postgresql://user:password@host:5432/railway"

# KredRegistry (F6) — on-chain disclosure anchor. Optional: the anchor UI + the
# "Anchored on-chain" badge stay dormant until this is set to a deployed address.
# Deploy with `npm run deploy:registry`, then paste the printed address here.
NEXT_PUBLIC_KRED_REGISTRY_ADDRESS=

# Deployer key for `npm run deploy:registry` ONLY (a funded Arc testnet wallet).
# Never commit a real key; leave blank unless you're deploying the contract.
DEPLOYER_PRIVATE_KEY=
